* Exemplo 5: O programa deve gerar uma imagem de dimensões 256x256 pixels contendo uma senóide de 4 períodos com amplitude de 127 desenhada na horizontal, como a imagem apresentada a seguir. Grave a imagem no formato PNG e no formato YML. Compare os arquivos gerados, extraindo uma linha de cada imagem gravada e comparando a diferença entre elas. Trace um gráfico da diferença calculada ao longo da linha correspondente extraída nas imagens. O que você observa?

[source,filestorage.cpp]
#include <iostream>
#include <opencv2/opencv.hpp>
#include <opencv2/plot.hpp>
#include <sstream>
#include <string>
#include "opencv2/plot.hpp" //Biblioteca para plotar o gráfico da diferença entre os dois arquivos de img
int SIDE = 256;
int PERIODOS = 4;
int main(int argc, char** argv)
{
    std::stringstream ss_img, ss_yml;
    cv::Mat image_yml, image_png;
    ss_yml << "senoideYML-" << SIDE << ".yml";
    // Gerando a imagem YML
    image_yml = cv::Mat::zeros(SIDE, SIDE, CV_32FC1);
    cv::FileStorage fs(ss_yml.str(), cv::FileStorage::WRITE);
    for (int i = 0; i < SIDE; i++)
    {
        for (int j = 0; j < SIDE; j++)
        {
            image_yml.at<float>(i, j) = 127 * sin(2 * M_PI * PERIODOS * j / SIDE) + 128;
        }
    }
    fs << "mat" << image_yml;
    fs.release();
    // Gerando a imagem PNG
    cv::normalize(image_yml, image_png, 0, 255, cv::NORM_MINMAX);
    image_png.convertTo(image_png, CV_8U);
    ss_img << "senoidePNG-" << SIDE << ".png";
    cv::imwrite(ss_img.str(), image_png);
    // Lendo as imagens geradas
    cv::FileStorage fs_yml(ss_yml.str(), cv::FileStorage::READ);
    fs_yml["mat"] >> image_yml;
    cv::normalize(image_yml, image_yml, 0, 255, cv::NORM_MINMAX);
    image_yml.convertTo(image_yml, CV_8U);
    image_png = cv::imread(ss_img.str(), cv::IMREAD_GRAYSCALE);
    // Calculando a diferença entre as linhas das imagens
    std::vector<double> diff(SIDE);
    for (int i = 0; i < SIDE; i++)
    {
        diff[i] = cv::sum(image_yml.row(i))[0] - cv::sum(image_png.row(i))[0];
    }
    // Cria um vetor com as posições das linhas
    std::vector<double> pos(SIDE);
    for (int i = 0; i < SIDE; i++) {
        pos[i] = i;
    }
    // Plotando o gráfico da diferença
    cv::Mat plot_result;
    cv::Mat plot_data(diff);
    cv::Ptr<cv::plot::Plot2d> plot = cv::plot::Plot2d::create(pos, diff);
    plot->setPlotBackgroundColor(cv::Scalar(50, 50, 50));
    plot->setPlotBackgroundColor(cv::Scalar(50, 50, 50));
    plot->setPlotLineColor(cv::Scalar(200, 200, 200));
    plot->setInvertOrientation(false);
    plot->setShowGrid(false);
    plot->render(plot_result);
    cv::waitKey();
    cv::imshow("YML Image", image_yml);
    cv::imshow("PNG Image", image_png);
    cv::imshow("Difference Plot", plot_result);
    cv::waitKey();
    return 0;
}

